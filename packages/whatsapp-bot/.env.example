PORT=8788
HOST=0.0.0.0

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=false
# Optional but recommended when signature validation is enabled.
TWILIO_WEBHOOK_PUBLIC_URL=https://your-public-host/twilio/whatsapp/webhook

VALUYA_GUARD_BASE_URL=https://pay.gorilla.build
VALUYA_TENANT_TOKEN=ttok_xxx
WHATSAPP_CHANNEL_APP_ID=whatsapp_main
WHATSAPP_PAID_CHANNEL_RESOURCE=whatsapp:channel:meta:premium_alpha:49123456789
WHATSAPP_PAID_CHANNEL_PLAN=standard
WHATSAPP_PAID_CHANNEL_VISIT_URL=https://chat.whatsapp.com/InviteCode
# Alternative resource construction:
# WHATSAPP_PAID_CHANNEL_PROVIDER=meta
# WHATSAPP_PAID_CHANNEL_IDENTIFIER=premium_alpha
# WHATSAPP_PAID_CHANNEL_PHONE=49123456789
# Dedicated resource used for marketplace order creation, delegated payment, and entitlement polling.
# Keep this separate from WHATSAPP_PAID_CHANNEL_RESOURCE.
VALUYA_ORDER_RESOURCE=whatsapp:bot:meta:alfies_whatsapp_marketplace:491234567890
# Backward-compatible fallback if VALUYA_ORDER_RESOURCE is unset.
VALUYA_RESOURCE=whatsapp:bot:meta:alfies_whatsapp_marketplace:491234567890
VALUYA_PLAN=standard
VALUYA_PAYMENT_ASSET=EURe
VALUYA_PAYMENT_CURRENCY=EUR
MARKETPLACE_PRODUCT_ID=47
MARKETPLACE_MERCHANT_SLUG=alfies

VALUYA_BACKEND_BASE_URL=https://pay.gorilla.build
VALUYA_BACKEND_TOKEN=ttok_xxx

# Optional OpenAI intent extraction. If unset, the bot uses deterministic parsing only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional live Alfies test-shop session setup from `address: ...` messages.
ALFIES_TEST_API_ENABLED=false
ALFIES_TEST_API_BASE_URL=https://test-api.alfies.shop/api/v1
ALFIES_TEST_COUNTRY_CODE=AT
ALFIES_TEST_DEFAULT_LATITUDE=48.2082
ALFIES_TEST_DEFAULT_LONGITUDE=16.3738
ALFIES_TEST_SHIPPING_METHOD=standard
# Optional curated live basket mapping used until a true Alfies search endpoint is integrated.
# Example:
# ALFIES_TEST_PRODUCT_MAP_JSON=[{"label":"Pasta Bundle","match":["pasta","spaghetti"],"products":[{"id":101,"quantity":1},{"id":202,"quantity":1}]}]
ALFIES_TEST_PRODUCT_MAP_JSON=
# Optional local Alfies catalog import file. Import separately via:
# pnpm --filter @valuya/whatsapp-bot import:alfies-catalog ./path/to/alfies-products.json

# Optional state file location (SQLite persistence for active conversations).
WHATSAPP_STATE_FILE=.data/whatsapp-state.sqlite
