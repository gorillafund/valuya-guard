{
  "name": "valuya-guard",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.10.2",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.scripts.json",
    "build:protocol": "pnpm --filter @valuya/protocol build",
    "test": "npm run test:gateway && npm run test:contract && npm run test:determinism",
    "test:contract": "node --test tests/contract/*.test.mjs",
    "test:gateway": "node --test docker/gateway/server.test.js",
    "test:determinism": "node --test tests/protocol-determinism.test.mjs",
    "protocol:snapshot": "node dist-scripts/generate-protocol-snapshot.js",
    "protocol:check": "node dist-scripts/check-rfc-consistency.js",
    "protocol:manifest": "node dist-scripts/generate-protocol-manifest.js",
    "protocol:changeset-check": "node dist-scripts/check-protocol-changeset.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "validate:openapi": "node scripts/ci/validate-openapi.js",
    "validate:contract-drift": "node scripts/ci/check-contract-drift.js",
    "validate:gated-channels": "pnpm build && node scripts/ci/check-gated-channel-presets.js",
    "lint:markdown": "bash scripts/ci/lint-markdown.sh",
    "gated-channel:new": "pnpm build && node dist-scripts/new-gated-channel.js",
    "gated-channel:launch": "pnpm build && node dist-scripts/launch-gated-channel.js",
    "gated-channel:doctor": "pnpm build && node dist-scripts/doctor-gated-channel.js",
    "gated-channel:runtime-demo": "pnpm build && node dist-scripts/external-soul-runtime-demo.js",
    "gated-channel:runtime-langchain": "pnpm build && node dist-scripts/langchain-runtime-reference.js",
    "validate:all": "pnpm lint:markdown && pnpm validate:openapi && pnpm validate:contract-drift && pnpm validate:gated-channels && pnpm test:gateway && pnpm test:contract",
    "publish:next": "./scripts/publish-next.sh",
    "publish:next:dry": "./scripts/publish-next.sh --dry-run",
    "publish:channels": "./scripts/publish-channel-packages.sh",
    "publish:channels:dry": "./scripts/publish-channel-packages.sh --dry-run",
    "publish:python": "./scripts/publish-python.sh",
    "publish:python:dry": "./scripts/publish-python.sh --dry-run"
  },
  "license": "MIT"
}
