{
  "name": "@valuya/whatsapp-bot",
  "version": "0.2.0-beta.1",
  "type": "module",
  "main": "dist/whatsapp-bot/src/server.js",
  "types": "dist/whatsapp-bot/src/server.d.ts",
  "scripts": {
    "build": "pnpm --filter @valuya/whatsapp-channel-access build && rm -rf dist && tsc -p tsconfig.json",
    "import:alfies-catalog": "pnpm run build && node dist/whatsapp-bot/src/alfiesCatalogImport.js",
    "normalize:alfies-catalog": "pnpm run build && node dist/whatsapp-bot/src/alfiesCatalogNormalize.js",
    "start": "node --env-file=.env dist/whatsapp-bot/src/server.js",
    "test": "pnpm run build && node --test dist/whatsapp-bot/src/*.test.js"
  },
  "dependencies": {
    "@valuya/agent": "workspace:^",
    "@valuya/whatsapp-channel-access": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^25.0.10"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "license": "MIT"
}
