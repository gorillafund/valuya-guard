PORT=8788
HOST=0.0.0.0

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=false
# Optional but recommended when signature validation is enabled.
TWILIO_WEBHOOK_PUBLIC_URL=https://your-public-host/twilio/whatsapp/webhook

N8N_CONCIERGE_URL=https://your-n8n-host/webhook/alfies/concierge

VALUYA_GUARD_BASE_URL=https://pay.gorilla.build
VALUYA_TENANT_TOKEN=ttok_xxx
WHATSAPP_CHANNEL_APP_ID=whatsapp_main
WHATSAPP_PAID_CHANNEL_RESOURCE=whatsapp:channel:meta:premium_alpha:49123456789
WHATSAPP_PAID_CHANNEL_PLAN=standard
WHATSAPP_PAID_CHANNEL_VISIT_URL=https://chat.whatsapp.com/InviteCode
# Alternative resource construction:
# WHATSAPP_PAID_CHANNEL_PROVIDER=meta
# WHATSAPP_PAID_CHANNEL_IDENTIFIER=premium_alpha
# WHATSAPP_PAID_CHANNEL_PHONE=49123456789
# Dedicated resource used for marketplace order creation, delegated payment, and entitlement polling.
# Keep this separate from WHATSAPP_PAID_CHANNEL_RESOURCE.
VALUYA_ORDER_RESOURCE=alfies.order
# Backward-compatible fallback if VALUYA_ORDER_RESOURCE is unset.
VALUYA_RESOURCE=alfies.order
VALUYA_PLAN=standard
VALUYA_PAYMENT_ASSET=EURe
VALUYA_PAYMENT_CURRENCY=EUR
MARKETPLACE_PRODUCT_ID=47
MARKETPLACE_MERCHANT_SLUG=alfies

VALUYA_BACKEND_BASE_URL=https://pay.gorilla.build
VALUYA_BACKEND_TOKEN=ttok_xxx

# Optional state file location (JSON persistence for active conversations).
WHATSAPP_STATE_FILE=.data/whatsapp-state.json
